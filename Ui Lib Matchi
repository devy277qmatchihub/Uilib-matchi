local Library = {}
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- Hệ thống Themes
local Themes = {
    Dark = { Main = Color3.fromRGB(20, 20, 20), Second = Color3.fromRGB(30, 30, 30), Text = Color3.fromRGB(255, 255, 255), Highlight = Color3.fromRGB(60, 60, 60) },
    Red = { Main = Color3.fromRGB(25, 10, 10), Second = Color3.fromRGB(35, 15, 15), Text = Color3.fromRGB(255, 255, 255), Highlight = Color3.fromRGB(200, 50, 50) },
    Aqua = { Main = Color3.fromRGB(15, 20, 25), Second = Color3.fromRGB(25, 30, 35), Text = Color3.fromRGB(255, 255, 255), Highlight = Color3.fromRGB(22, 171, 234) }, -- Màu Highlight chuẩn
    Light = { Main = Color3.fromRGB(240, 240, 240), Second = Color3.fromRGB(255, 255, 255), Text = Color3.fromRGB(20, 20, 20), Highlight = Color3.fromRGB(200, 200, 200) }
}

function Library:MakeWindow(Config)
    local WindowName = Config.Name or "Unnamed Library"
    local LeftIcon = Config.Icon or ""
    local CloseIcon = Config.CloseId or ""
    local Theme = Themes[Config.Theme] or Themes.Aqua

    -- Tạo ScreenGui (Chỉ tạo khi gọi hàm này)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "CustomLibraryUI"
    ScreenGui.Parent = (game:GetService("RunService"):IsStudio() and game.Players.LocalPlayer:WaitForChild("PlayerGui")) or CoreGui
    ScreenGui.ResetOnSpawn = false

    -- Main Frame
    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Size = UDim2.new(0, 650, 0, 400)
    Main.Position = UDim2.new(0.5, -325, 0.5, -200)
    Main.BackgroundColor3 = Theme.Main
    Main.Parent = ScreenGui
    
    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = Main

    -- Topbar
    local Topbar = Instance.new("Frame")
    Topbar.Size = UDim2.new(1, 0, 0, 40)
    Topbar.BackgroundTransparency = 1
    Topbar.Parent = Main

    -- Left Icon (Góc trái)
    if LeftIcon ~= "" then
        local IconL = Instance.new("ImageLabel")
        IconL.Size = UDim2.new(0, 25, 0, 25)
        IconL.Position = UDim2.new(0, 10, 0, 7)
        IconL.BackgroundTransparency = 1
        IconL.Image = LeftIcon
        IconL.Parent = Topbar
    end

    -- Title
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(0, 200, 1, 0)
    Title.Position = UDim2.new(0, (LeftIcon ~= "" and 45 or 15), 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = WindowName
    Title.TextColor3 = Theme.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = Topbar

    -- Close Button (Góc phải)
    local CloseBtn = Instance.new("ImageButton")
    CloseBtn.Size = UDim2.new(0, 25, 0, 25)
    CloseBtn.Position = UDim2.new(1, -35, 0, 7)
    CloseBtn.BackgroundTransparency = 1
    if CloseIcon ~= "" then
        CloseBtn.Image = CloseIcon
    else
        -- Dùng text X nếu không có hình
        CloseBtn.Image = ""
        local XText = Instance.new("TextLabel")
        XText.Size = UDim2.new(1,0,1,0)
        XText.BackgroundTransparency = 1
        XText.Text = "X"
        XText.TextColor3 = Theme.Text
        XText.Font = Enum.Font.GothamBold
        XText.TextSize = 16
        XText.Parent = CloseBtn
    end
    CloseBtn.Parent = Topbar
    CloseBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)

    -- Sidebar (Menu bên trái)
    local Sidebar = Instance.new("ScrollingFrame")
    Sidebar.Size = UDim2.new(0, 150, 1, -40)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundTransparency = 1
    Sidebar.BorderSizePixel = 0
    Sidebar.ScrollBarThickness = 0
    Sidebar.Parent = Main

    local SidebarLayout = Instance.new("UIListLayout")
    SidebarLayout.Padding = UDim.new(0, 5)
    SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    SidebarLayout.Parent = Sidebar

    -- Container Content (Khu vực chứa UI bên phải)
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -160, 1, -50)
    ContentContainer.Position = UDim2.new(0, 150, 0, 40)
    ContentContainer.BackgroundColor3 = Theme.Second
    ContentContainer.Parent = Main
    
    local ContentCorner = Instance.new("UICorner")
    ContentCorner.CornerRadius = UDim.new(0, 6)
    ContentCorner.Parent = ContentContainer

    -- Make UI Dragable (Kéo thả cơ bản)
    local dragging, dragInput, dragStart, startPos
    Topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)

    -- Hàm xử lý bên trong Window
    local Elements = {}

    function Elements:MakeDiscordBanner(D_Config)
        local Banner = Instance.new("Frame")
        Banner.Size = UDim2.new(1, -20, 0, 150)
        Banner.Position = UDim2.new(0, 10, 0, 10)
        Banner.BackgroundColor3 = Theme.Main
        Banner.ClipsDescendants = true
        Banner.Parent = ContentContainer

        local BCorner = Instance.new("UICorner")
        BCorner.CornerRadius = UDim.new(0, 6)
        BCorner.Parent = Banner

        local Img = Instance.new("ImageLabel")
        Img.Size = UDim2.new(1, 0, 0, 90)
        Img.Image = D_Config.BannerId or ""
        Img.ScaleType = Enum.ScaleType.Crop
        Img.Parent = Banner

        local InfoFrame = Instance.new("Frame")
        InfoFrame.Size = UDim2.new(1, 0, 0, 60)
        InfoFrame.Position = UDim2.new(0, 0, 0, 90)
        InfoFrame.BackgroundTransparency = 1
        InfoFrame.Parent = Banner

        local Title = Instance.new("TextLabel")
        Title.Size = UDim2.new(0.7, 0, 0.5, 0)
        Title.Position = UDim2.new(0, 10, 0, 5)
        Title.BackgroundTransparency = 1
        Title.Text = D_Config.Title or "Discord Community"
        Title.TextColor3 = Theme.Text
        Title.Font = Enum.Font.GothamBold
        Title.TextXAlignment = Enum.TextXAlignment.Left
        Title.Parent = InfoFrame

        local JoinBtn = Instance.new("TextButton")
        JoinBtn.Size = UDim2.new(0, 100, 0, 30)
        JoinBtn.Position = UDim2.new(1, -110, 0, 15)
        JoinBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 60) -- Màu xanh lá nút Join
        JoinBtn.Text = "Join"
        JoinBtn.TextColor3 = Color3.fromRGB(255,255,255)
        JoinBtn.Font = Enum.Font.GothamBold
        JoinBtn.Parent = InfoFrame
        
        local BtnCorner = Instance.new("UICorner")
        BtnCorner.CornerRadius = UDim.new(0, 6)
        BtnCorner.Parent = JoinBtn

        JoinBtn.MouseButton1Click:Connect(function()
            setclipboard(D_Config.Link)
            JoinBtn.Text = "Copied Link!"
            task.wait(2)
            JoinBtn.Text = "Join"
        end)
    end

    function Elements:MakeToggle(T_Config)
        -- Tạo khung Toggle
        local ToggleFrame = Instance.new("Frame")
        ToggleFrame.Size = UDim2.new(1, -20, 0, 60)
        ToggleFrame.Position = UDim2.new(0, 10, 0, 170) -- Tạm thời set Position tĩnh, khi dùng thật nên xài UIListLayout
        ToggleFrame.BackgroundColor3 = Theme.Main
        ToggleFrame.Parent = ContentContainer

        local TCorner = Instance.new("UICorner")
        TCorner.CornerRadius = UDim.new(0, 6)
        TCorner.Parent = ToggleFrame

        -- Icon
        local TIcon = Instance.new("ImageLabel")
        TIcon.Size = UDim2.new(0, 40, 0, 40)
        TIcon.Position = UDim2.new(0, 10, 0, 10)
        TIcon.BackgroundColor3 = Theme.Highlight
        TIcon.Image = T_Config.Icon or "rbxassetid://12345678" -- Thay icon mặc định vào đây
        TIcon.Parent = ToggleFrame
        Instance.new("UICorner", TIcon).CornerRadius = UDim.new(0, 8)

        local TTitle = Instance.new("TextLabel")
        TTitle.Size = UDim2.new(0, 200, 0, 20)
        TTitle.Position = UDim2.new(0, 60, 0, 10)
        TTitle.BackgroundTransparency = 1
        TTitle.Text = T_Config.Name or "Toggle"
        TTitle.TextColor3 = Theme.Text
        TTitle.Font = Enum.Font.GothamBold
        TTitle.TextXAlignment = Enum.TextXAlignment.Left
        TTitle.Parent = ToggleFrame

        -- Switch (Công tắc)
        local SwitchBg = Instance.new("Frame")
        SwitchBg.Size = UDim2.new(0, 40, 0, 20)
        SwitchBg.Position = UDim2.new(1, -50, 0, 20)
        SwitchBg.BackgroundColor3 = Theme.Second
        SwitchBg.Parent = ToggleFrame
        Instance.new("UICorner", SwitchBg).CornerRadius = UDim.new(1, 0)

        local SwitchDot = Instance.new("Frame")
        SwitchDot.Size = UDim2.new(0, 16, 0, 16)
        SwitchDot.Position = UDim2.new(0, 2, 0, 2)
        SwitchDot.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
        SwitchDot.Parent = SwitchBg
        Instance.new("UICorner", SwitchDot).CornerRadius = UDim.new(1, 0)

        local Toggled = false
        ToggleFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                Toggled = not Toggled
                if Toggled then
                    TweenService:Create(SwitchDot, TweenInfo.new(0.2), {Position = UDim2.new(1, -18, 0, 2), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
                    TweenService:Create(SwitchBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Highlight}):Play()
                    ToggleFrame.UIStroke.Color = Theme.Highlight -- Đổi viền
                else
                    TweenService:Create(SwitchDot, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0, 2), BackgroundColor3 = Color3.fromRGB(200,200,200)}):Play()
                    TweenService:Create(SwitchBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Second}):Play()
                    ToggleFrame.UIStroke.Color = Theme.Main
                end
                pcall(T_Config.Callback, Toggled)
            end
        end)
        
        -- Thêm viền khi active giống hình
        local Stroke = Instance.new("UIStroke")
        Stroke.Color = Theme.Main
        Stroke.Thickness = 1.5
        Stroke.Parent = ToggleFrame
    end

    -- Hàm Slider cơ bản (để ông có thể mở rộng thêm)
    function Elements:MakeSlider(S_Config)
        -- Code cấu trúc Slider tương tự Toggle
    end

    return Elements
end

return Library
